# ISA-Forge Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Provider Configuration
# =============================================================================

# LLM provider: anthropic, google, or ollama
ISAFORGE_LLM_PROVIDER=anthropic

# Model name (provider-specific)
ISAFORGE_LLM_MODEL=claude-3-sonnet-20240229

# API keys (required for cloud providers)
ISAFORGE_ANTHROPIC_API_KEY=your-anthropic-api-key-here
ISAFORGE_GOOGLE_API_KEY=your-google-api-key-here

# Ollama configuration (for local LLM)
ISAFORGE_OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# NCBI API Configuration
# =============================================================================

# NCBI API key (optional, but recommended for higher rate limits)
# Get one at: https://www.ncbi.nlm.nih.gov/account/settings/
ISAFORGE_NCBI_API_KEY=

# Email for NCBI API identification (recommended)
ISAFORGE_NCBI_EMAIL=your-email@example.com

# =============================================================================
# Session Management
# =============================================================================

# Path to SQLite database for session storage
ISAFORGE_SESSION_DB_PATH=~/.isaforge/sessions.db

# =============================================================================
# Confidence & Conversation Settings
# =============================================================================

# Confidence threshold for auto-accepting fields (0.0-1.0)
ISAFORGE_CONFIDENCE_THRESHOLD=0.9

# Maximum conversation turns before timeout
ISAFORGE_MAX_CONVERSATION_TURNS=50

# Maximum retries per field before giving up
ISAFORGE_MAX_RETRIES_PER_FIELD=3

# Maximum tool calls per conversation turn
ISAFORGE_MAX_TOOL_CALLS_PER_TURN=10

# Maximum publications to fetch per BioProject
ISAFORGE_MAX_PUBLICATIONS=6

# =============================================================================
# Ontology Services
# =============================================================================

# OLS (Ontology Lookup Service) base URL
ISAFORGE_OLS_BASE_URL=https://www.ebi.ac.uk/ols4/api

# Zooma annotation service base URL
ISAFORGE_ZOOMA_BASE_URL=https://www.ebi.ac.uk/spot/zooma/v2

# Preferred ontologies for term mapping (comma-separated)
ISAFORGE_PREFERRED_ONTOLOGIES=OBI,EFO,NCIT,UBERON,CL,CHEBI

# =============================================================================
# Validation
# =============================================================================

# Use strict validation (fail on warnings)
ISAFORGE_VALIDATION_STRICT=false

# =============================================================================
# Logging & Observability
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
ISAFORGE_LOG_LEVEL=INFO

# Optional: LangSmith tracing (for debugging LLM calls)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-api-key
# LANGCHAIN_PROJECT=isaforge
